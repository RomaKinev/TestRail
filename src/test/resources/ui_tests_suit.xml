<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="UI Regression tests" verbose="1">

    <test name="UI Tests">
        <groups>
            <run>
                <include name="ui"/>
                <!-- Smoke scenarios run in their own suite and must not be duplicated here. -->
                <exclude name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="tests.ui"/>
        </packages>
    </test>
</suite>